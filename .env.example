# Supabase — copy to .env.local and fill in from your project's Settings → API.
# Only these two public values are needed (the app uses anonymous auth + RLS;
# the service-role key must NOT be exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# MiniMax — the app's AI engine. Server-side only: the key is read by
# /api/coach and never reaches the browser. Get one at https://platform.minimax.io
MINIMAX_API_KEY=your-minimax-api-key

# Optional overrides.
# MINIMAX_MODEL=MiniMax-M2.1        # also: MiniMax-M3, MiniMax-M2.5, *-highspeed
# MINIMAX_BASE_URL=https://api.minimax.io/v1
